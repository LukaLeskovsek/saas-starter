# =============================================================================
# Environment variables — the contract for this app.
#
# Keys live here (locally, in .env.local) and in your Vercel project settings —
# never in code, never in chat, never in the knowledge base.
#
# Setup: copy this file to ".env.local" and fill in the blanks. .env.local is
# gitignored, so your real keys never get committed. Ask Claude Code to walk you
# through it one variable at a time.
# =============================================================================

# --- Supabase: sign-in + database ---
# Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=           # your project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=      # the anon / publishable key — safe in the browser; RLS is the real protection

# Lets Claude Code apply your database migrations for you (no pasting SQL into the dashboard).
# Create at supabase.com → Account → Access Tokens. Account-scoped — it's your own account; revoke after the program.
SUPABASE_ACCESS_TOKEN=

# Reserved — NOT used by this template (anon key + RLS is enough). If you ever
# add it, it is SERVER-ONLY: never prefix it with NEXT_PUBLIC, never put it in code.
# SUPABASE_SERVICE_ROLE_KEY=

# --- Resend: the app's transactional email ---
# Resend dashboard → API Keys
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev    # workshop default (test sender, delivers to your own account email).
                                    # Use your own verified domain after the program.

# --- Sentry: error tracking ---
# Sentry → your project → Settings → Client Keys (DSN). The DSN is public (safe in the browser).
NEXT_PUBLIC_SENTRY_DSN=
# Optional — set these on Vercel to upload source maps (leave blank locally):
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# --- AI: the app's LLM calls (lib/ai.ts) ---
# The SAME OpenRouter key your Hermes agent uses (openrouter.ai → Keys), capped.
# SERVER-ONLY: never prefix with NEXT_PUBLIC, never put it in code. Leave blank to
# run in mock mode (canned AI output, zero spend) — the feature still works.
OPENROUTER_API_KEY=
# Default model is Claude via OpenRouter. Verify the current slug at
# openrouter.ai/models. Switch to an OpenAI model id here to swap providers.
OPENROUTER_MODEL=anthropic/claude-3.5-haiku
# Max real OpenRouter calls per signed-in user per UTC day. Blank defaults to 20.
AI_DAILY_LIMIT_PER_USER=20

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000   # your Vercel URL in production
